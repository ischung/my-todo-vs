{
  "name": "my-todo-vs",
  "version": "0.1.0",
  "private": true,
  "description": "날짜별 할일 관리 앱 — Containerized Monolith (Express + React + SQLite), GHCR 기반 배포",
  "workspaces": [
    "frontend",
    "backend",
    "e2e"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm start --workspace=backend",
    "lint": "eslint \"{backend,frontend,e2e,scripts}/**/*.{js,jsx}\" --max-warnings=0",
    "format": "prettier --write \"{backend,frontend,e2e,scripts}/**/*.{js,jsx,json,css,html,md}\"",
    "test": "npm test --workspaces --if-present"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
